-- GRAV BOOST
local function setupGravBoost(char) local root=char:WaitForChild("HumanoidRootPart"); root.Touched:Connect(function(hit) if not gravBoostOn or not boostRequested then return end; boostRequested=false; local oc=hit.Parent; local op=Players:GetPlayerFromCharacter(oc); if op and op~=plr then local h=oc:FindFirstChild("Head"); if h and h.CanCollide then local last=lastBoostTimes[op] or 0; if tick()-last>=gravBoostCooldown then local hum=char:FindFirstChild("Humanoid"); local md=hum and hum.MoveDirection or Vector3.zero; local bv=Instance.new("BodyVelocity"); bv.Velocity=Vector3.new(md.X*5,gravBoostPower,md.Z*5); bv.MaxForce=Vector3.new(9e9,9e9,9e9); bv.Parent=root; Debris:AddItem(bv,0.1); lastBoostTimes[op]=tick() end end end end) end

-- SELFTYZ: STICKY HEAD
local function startSticky() local target=findNearestPlayer(); if not target or not target.Character then return end; stickyTarget=target; if stickyConn then stickyConn:Disconnect() end; stickyConn=RunService.Heartbeat:Connect(function() if not stickyOn or not stickyTarget or not stickyTarget.Character then if stickyConn then stickyConn:Disconnect(); stickyConn=nil end; stickyTarget=nil; return end; local h=stickyTarget.Character:FindFirstChild("Head"); if h and rootPart then rootPart.CFrame=CFrame.new(h.Position+Vector3.new(0,2,0)) else if stickyConn then stickyConn:Disconnect(); stickyConn=nil end; stickyTarget=nil end end) end
local function stopSticky() if stickyConn then stickyConn:Disconnect(); stickyConn=nil end; stickyTarget=nil end

-- AUTO TTB (Tag Team Boost — when on someone's head, both boost up)
local function setupAutoTTB(char)
    if not char then return end
    local r = char:WaitForChild("HumanoidRootPart", 5)
    if not r then return end
    r.Touched:Connect(function(hit)
        if not autoTTBEnabled or not canTTB then return end
        local otherChar = hit:FindFirstAncestorWhichIsA("Model")
        if not otherChar or otherChar == char then return end
        local otherHum = otherChar:FindFirstChild("Humanoid")
        local otherRoot = otherChar:FindFirstChild("HumanoidRootPart")
        if not otherHum or not otherRoot then return end
        local otherPlayer = Players:GetPlayerFromCharacter(otherChar)
        if not otherPlayer then return end
        -- Check if we are ABOVE them (on their head)
        local yDiff = r.Position.Y - otherRoot.Position.Y
        if yDiff > 1.5 and yDiff < 8 then
            canTTB = false
            -- Boost ME up
            local bv = Instance.new("BodyVelocity")
            bv.Velocity = Vector3.new(r.AssemblyLinearVelocity.X * 0.3, ttbPower, r.AssemblyLinearVelocity.Z * 0.3)
            bv.MaxForce = Vector3.new(0, math.huge, 0)
            bv.P = 5000
            bv.Parent = r
            Debris:AddItem(bv, 0.25)
            task.delay(ttbCooldown, function() canTTB = true end)
        end
    end)
end

