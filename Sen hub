-- [[ FUNCTIONS ]]
local function findNameLabels()
    cachedNameLabels = {}
    
    -- Search character
    for _, v in pairs(lp.Character:GetDescendants()) do
        if v:IsA("TextLabel") then
            if v.Name == "NameTag" or v.Name == "PlayerName" or v.Name == "Username" or 
               (v.Text and v.Text == originalName) or (v.Text and v.Text == spoofedName) then
                table.insert(cachedNameLabels, v)
            end
        end
    end
    
    -- Search PlayerGui
    local playerGui = lp:FindFirstChild("PlayerGui")
    if playerGui then
        for _, v in pairs(playerGui:GetDescendants()) do
            if v:IsA("TextLabel") and (v.Text == originalName or v.Text == spoofedName) then
                table.insert(cachedNameLabels, v)
            end
        end
    end
end

