-- =========================
-- SLOT GUESS (FULL)
-- =========================
local function guessSlot(name)
    local nm = name:lower()
    if nm:find("face") or nm:find("shade") then return "FaceAccessory" end
    if nm:find("hair") or nm:find("scene") then return "HairAccessory" end
    if nm:find("neck") or nm:find("chain") then return "NeckAccessory" end
    if nm:find("back") then return "BackAccessory" end
    if nm:find("waist") then return "WaistAccessory" end
    if nm:find("shoulder") then return "ShouldersAccessory" end
    return "HatAccessory"
end

-- =========================
-- EQUIP MESH
-- =========================
local function equipMeshItem(name)
    if equipped[name] then return end
    local d = MESH_ITEMS[name]
    if not d then return end

    local par = character:FindFirstChild(d.par) or character:FindFirstChild("Torso")
    if not par then return end

    local part = Instance.new("Part")
    part.Name = name
    part.Size = Vector3.new(1,1,1)
    part.CanCollide = false
    part.Massless = true
    part.Parent = character

    local mesh = Instance.new("SpecialMesh", part)
    mesh.MeshId = d.mesh
    mesh.TextureId = d.tex
    mesh.Scale = d.scl

    local weld = Instance.new("Motor6D", par)
    weld.Part0 = par
    weld.Part1 = part
    weld.C0 = d.off

    equipped[name] = {part}
end

-- =========================
-- EQUIP CLOTHING (ALL METHODS)
-- =========================
local function equipClothing(name)
    if equipped[name] then return end
    local d = CLOTHING_ITEMS[name]
    if not d then return end

    local char = character
    local hum = char:FindFirstChildOfClass("Humanoid")
    local idStr = tostring(d.assetId)

    local applied = false
    local appliedParts = {}

    -- METHOD 1 (GetObjects)
    pcall(function()
        local objs = game:GetObjects("rbxassetid://"..idStr)
        for _, obj in pairs(objs) do
            for _, v in pairs(obj:GetDescendants()) do
                if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") then
                    v.Parent = char
                    if hum and v:IsA("Accessory") then hum:AddAccessory(v) end
                    table.insert(appliedParts, v)
                    applied = true
                end
            end
        end
    end)

    -- METHOD 2 (InsertService)
    if not applied then
        pcall(function()
            local model = InsertService:LoadAsset(d.assetId)
            for _, v in pairs(model:GetDescendants()) do
                if v:IsA("Accessory") then
                    v.Parent = char
                    hum:AddAccessory(v)
                    table.insert(appliedParts, v)
                    applied = true
                end
            end
            model:Destroy()
        end)
    end

    -- METHOD 3 (Dummy Model)
    if not applied and hum then
        pcall(function()
            local desc = Instance.new("HumanoidDescription")
            desc[guessSlot(name)] = idStr

            local dummy = Players:CreateHumanoidModelFromDescription(desc, Enum.HumanoidRigType.R15)
            for _, v in pairs(dummy:GetChildren()) do
                if v:IsA("Accessory") then
                    v.Parent = char
                    hum:AddAccessory(v)
                    table.insert(appliedParts, v)
                    applied = true
                end
            end
            dummy:Destroy()
        end)
    end

    -- METHOD 4 (Classic clothing fallback)
    if not applied then
        if d.type == "Shirt" then
            local s = Instance.new("Shirt", char)
            s.ShirtTemplate = "rbxassetid://"..idStr
            table.insert(appliedParts, s)
            applied = true
        elseif d.type == "Pants" then
            local p = Instance.new("Pants", char)
            p.PantsTemplate = "rbxassetid://"..idStr
            table.insert(appliedParts, p)
            applied = true
        end
    end

    if applied then
        equipped[name] = appliedParts
    end
end

