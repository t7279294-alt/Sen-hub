    if not f then local pmm=Workspace:FindFirstChild("ParkMatchMap"); if pmm and pmm:FindFirstChild("Replicated") then local f2=pmm.Replicated:FindFirstChild("Fields"); if f2 and f2:FindFirstChild("MatchField") then local r2=f2.MatchField:FindFirstChild("Replicated"); if r2 then local fb=r2:FindFirstChild("Football"); if fb and fb:IsA("BasePart") then f=fb end end end end end
    if not f then for _,folder in ipairs({Workspace:FindFirstChild("Games"),Workspace:FindFirstChild("MiniGames")}) do if folder then for _,gi in ipairs(folder:GetChildren()) do local rep=gi:FindFirstChild("Replicated"); if rep then local kf=rep:FindFirstChild("918f5408-d86a-4fb8-a88c-5cab57410acf"); if kf and kf:IsA("BasePart") then f=kf; break end; for _,item in ipairs(rep:GetChildren()) do if item:IsA("BasePart") and item.Name=="Football" then f=item; break end end; if f then break end end end; if f then break end end end end
    if not f then for _,p in ipairs(Players:GetPlayers()) do if p.Character then local fb=p.Character:FindFirstChild("Football"); if fb and fb:IsA("BasePart") then f=fb; break end end end end
    if not f then for _,o in ipairs(Workspace:GetChildren()) do if o.Name=="Football" and o:IsA("BasePart") then f=o; break end end end
    _bc=f; _bt=now; return f
