-- [[ ITEMS TAB ]]
ItemTab:CreateSection("Accessories")

local ACCESSORY_DATA = {
    AllStarGear = { mesh = "rbxassetid://13410505140", texture = "rbxassetid://13410505151", parent = "UpperTorso", scale = Vector3.new(1,1,1), offset = CFrame.new(0, 0, 0) },
    InfBandanna = { mesh = "rbxassetid://13540050100", texture = "rbxassetid://13540050115", parent = "Head", scale = Vector3.new(1.05,1.05,1.05), offset = CFrame.new(0, 0.1, 0) }
}

local function equipItem(name)
    if equippedAccessories[name] then return end
    local data = ACCESSORY_DATA[name]
    local p_part = lp.Character:FindFirstChild(data.parent)
    if not p_part then return end

    local part = Instance.new("Part", lp.Character)
    part.Name = name
    part.Size = Vector3.new(1,1,1)
    part.CanCollide = false
    part.Massless = true

    local mesh = Instance.new("SpecialMesh", part)
    mesh.MeshType = Enum.MeshType.FileMesh
    mesh.MeshId = data.mesh
    mesh.TextureId = data.texture
    mesh.Scale = data.scale

    local weld = Instance.new("Motor6D", p_part)
    weld.Part0 = p_part
    weld.Part1 = part
    weld.C0 = data.offset

    equippedAccessories[name] = part
end

for name, _ in pairs(ACCESSORY_DATA) do
    ItemTab:CreateToggle({
        Name = name,
        CurrentValue = false,
        Callback = function(v)
            if v then
                equipItem(name)
            else
                if equippedAccessories[name] then
                    equippedAccessories[name]:Destroy()
                    equippedAccessories[name] = nil
                end
            end
        end
    })
end

