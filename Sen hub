-- [[ HEARTBEAT LOOP ]]
game:GetService("RunService").Heartbeat:Connect(function()
    if not root or not lp.Character then return end

    if hitboxEnabled then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = p.Character.HumanoidRootPart

                hrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                hrp.Transparency = hitboxTransparency

                -- optional visual
                hrp.Material = Enum.Material.ForceField
            end
        end
    end

    -- Banner spoof
    for _, v in pairs(lp.Character:GetDescendants()) do
        if v:IsA("ImageLabel") and v.Visible and v.AbsoluteSize.X > v.AbsoluteSize.Y then
            if not originalBannerID then
                originalBannerID = v.Image
            end
            v.Image = currentBannerID
        end
    end
end)

-- [[ NAME SPOOF LOOP (Separate slower loop to prevent lag) ]]
spawn(function()
    while wait(0.1) do -- Only runs 10 times per second instead of 60+
        if nameChangerEnabled then
            -- Update cached labels
            for _, label in pairs(cachedNameLabels) do
                if label and label.Parent then
                    label.Text = spoofedName
                end
            end
            
            -- Refresh cache every second
            if tick() - lastNameUpdate > 1 then
                findNameLabels()
                lastNameUpdate = tick()
            end
        end
    end
end)

