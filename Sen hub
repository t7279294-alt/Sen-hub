local _bc,_bt=nil,0
local function getFootball()
    local now=tick(); if _bc and _bc.Parent and _bc:IsDescendantOf(game) and (now-_bt)<0.5 then return _bc end; _bc=nil; local f=nil
    local pm=Workspace:FindFirstChild("ParkMap")
